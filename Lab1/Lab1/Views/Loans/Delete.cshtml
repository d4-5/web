@model Lab1.Models.Loan

@{
    ViewData["Title"] = "Delete Loan";
}

<h1>Delete Loan</h1>

<h3>Are you sure you want to delete this loan record?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Reader</dt>
        <dd class="col-sm-9">@Model.Reader?.FullName</dd>
        <dt class="col-sm-3">Book</dt>
        <dd class="col-sm-9">@Model.Book?.Title</dd>
        <dt class="col-sm-3">Issued At</dt>
        <dd class="col-sm-9">@Model.IssuedAt.ToString("yyyy-MM-dd")</dd>
        <dt class="col-sm-3">Due At</dt>
        <dd class="col-sm-9">@Model.DueAt.ToString("yyyy-MM-dd")</dd>
        <dt class="col-sm-3">Returned At</dt>
        <dd class="col-sm-9">@Model.ReturnedAt?.ToString("yyyy-MM-dd")</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
