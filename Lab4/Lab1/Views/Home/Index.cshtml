@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-5">Library Information System</h1>
    <p>
        <a asp-controller="Readers" asp-action="Index" class="btn btn-outline-primary me-2">Readers</a>
        <a asp-controller="Books" asp-action="Index" class="btn btn-outline-primary me-2">Books</a>
        <a asp-controller="Loans" asp-action="Index" class="btn btn-primary">Loans</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Chat" asp-action="Index" class="btn btn-outline-success ms-2">Open Chat</a>
        }
    </p>
</div>
